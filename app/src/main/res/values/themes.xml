<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Calculator" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/red_copper_dk</item>
        <item name="colorPrimaryVariant">@color/copper</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/khaki_green</item>
        <item name="colorSecondaryVariant">@color/dark_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@drawable/calc_back</item>
    </style>

    <!-- Buttons -->
    <style name="ButtonBasic" parent="Theme.Calculator">
        <item name="android:layout_width">@dimen/basicButtonLayoutWidth</item>
        <item name="android:layout_height">@dimen/basicButtonLayoutHeight</item>
        <item name="android:textSize">@dimen/basicButtonTextSize</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ButtonBasic.NumberButton">
        <item name="backgroundTint">@color/golden_brown</item>
    </style>

    <style name="ButtonBasic.NumberButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="ButtonBasic.NumberButton.ButtonZero">
        <item name="android:layout_width">@dimen/zeroWidth</item>
    </style>

    <style name="ButtonBasic.OperatorButton">
        <item name="backgroundTint">@color/khaki_green</item>
    </style>

    <style name="ButtonBasic.OperatorButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="ButtonBasic.OperatorButton.WithMarginEnd.WithMarginStart">
        <item name="android:layout_marginStart">@dimen/layoutMarginStart</item>
    </style>

    <style name="ButtonBasic.OperatorButton.ButtonEqual">
        <item name="android:layout_height">@dimen/zeroHeight</item>
        <item name="backgroundTint">@color/red_copper_dk</item>
    </style>

    <style name="DeleteButton">
        <item name="android:layout_width">@dimen/deleteButtonWidth</item>
        <item name="android:layout_height">@dimen/deleteButtonHeight</item>
        <item name="android:textSize">@dimen/deleteButtonTextSize</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/red_copper_dk</item>
    </style>

    <style name="DeleteButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="EditTextBasic">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/editTextLayoutHeight</item>
        <item name="android:textAlignment">textEnd</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/editTextSize</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EditTextBasic.WithMarginTop">
        <item name="android:layout_marginTop">@dimen/calcFieldMarginTop</item>
    </style>

    <style name="EditTextBasic.WithMarginTop.WithMarginBottom">
        <item name="android:layout_marginTop">@dimen/layoutMarginTop</item>
        <item name="android:layout_marginBottom">@dimen/layoutMarginBottom</item>
    </style>

    <style name="ButtonBasic.OperatorButton.SwitchButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/switchButton</item>
        <item name="android:textSize">@dimen/switchButtonText</item>
    </style>

    <!-- Landscape buttons -->
    <style name="LandButtonBasic">
        <item name="android:layout_width">@dimen/landBasicButtonLayoutWidth</item>
        <item name="android:layout_height">@dimen/landBasicButtonLayoutHeight</item>
        <item name="android:textSize">@dimen/landBasicButtonTextSize</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="LandButtonBasic.NumberButton">
        <item name="backgroundTint">@color/golden_brown</item>
    </style>

    <style name="LandButtonBasic.NumberButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="LandButtonBasic.NumberButton.ButtonZero">
        <item name="android:layout_width">@dimen/zeroWidth</item>
    </style>

    <style name="LandButtonBasic.OperatorButton">
        <item name="backgroundTint">@color/khaki_green</item>
    </style>

    <style name="LandButtonBasic.OperatorButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="LandButtonBasic.OperatorButton.WithMarginEnd.WithMarginStart">
        <item name="android:layout_marginStart">@dimen/layoutMarginStart</item>
    </style>

    <style name="LandButtonBasic.OperatorButton.ButtonEqual">
        <item name="android:layout_height">@dimen/zeroHeight</item>
        <item name="backgroundTint">@color/red_copper_dk</item>
    </style>

    <style name="LandDeleteButton">
        <item name="android:layout_width">@dimen/landDeleteButtonWidth</item>
        <item name="android:layout_height">@dimen/landDeleteButtonHeight</item>
        <item name="android:textSize">@dimen/landDeleteButtonTextSize</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/red_copper_dk</item>
    </style>

    <style name="LandDeleteButton.WithMarginEnd">
        <item name="android:layout_marginEnd">@dimen/layoutMarginEnd</item>
    </style>

    <style name="LandEditTextBasic">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/landEditTextLayoutHeight</item>
        <item name="android:textAlignment">textEnd</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/landEditTextSizeCalculation</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LandEditTextBasic.ResultTextView">
        <item name="android:textSize">@dimen/landEditTextSizeResult</item>
    </style>

    <style name="LandButtonBasic.OperatorButton.SwitchButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/landSwitchButton</item>
        <item name="android:textSize">@dimen/switchButtonText</item>
    </style>

